# EN: Boot character models shipped with the template (see docs/REQUIRED_MODELS.md).
!public/models/characters/
public/models/characters/**
!public/models/characters/men/
!public/models/characters/women/
public/models/characters/men/**
!public/models/characters/men/men-all.glb
!public/models/characters/men/men_shape.png
public/models/characters/women/**
!public/models/characters/women/women-all.glb
!public/models/characters/women/women-shape.png
!public/models/characters/README.md

