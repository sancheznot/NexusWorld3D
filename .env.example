# =============================================================================
# NexusWorld3D — environment entry point (no real secrets here)
# =============================================================================
# EN: For full bilingual comments and optional sections, copy the detailed file:
#       cp .env.local.example .env.local
# ES: Para Docker (app + MariaDB), usa también:
#       cp env.docker.example .env
#     y unifica credenciales con docker-compose.yml.
# See docs/DEPLOYMENT.md
# =============================================================================

NODE_ENV=development
PORT=3000
COLYSEUS_PORT=3001

NEXT_PUBLIC_APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001

NEXT_PUBLIC_GAME_NAME=NexusWorld3D
NEXT_PUBLIC_COLYSEUS_ROOM=nexus-world

ADMIN_USERNAME_ACCESS=admin
ADMIN_PASSWORD_ACCESS=replace_with_strong_password

# Optional: Upstash Redis (otherwise in-memory mock may be used)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: MariaDB (see .env.local.example)
# MARIADB_HOST=127.0.0.1
# MARIADB_PORT=3306
# MARIADB_USER=nexus
# MARIADB_PASSWORD=
# MARIADB_DATABASE=nexusworld3d

# Optional: framework demo map (flat ground + demo cube)
# NEXT_PUBLIC_FRAMEWORK_DEMO=1

# Optional: second Colyseus room template for scene authoring tests (same NexusWorldRoom class)
# NEXUS_ENABLE_STAGING_WORLD_ROOM=1
# NEXUS_STAGING_WORLD_ROOM_NAME=nexus-world-staging
# Restrict apply/merge to that template only (HTTP + WebSocket tooling)
# NEXUS_SCENE_AUTHORING_STAGING_ONLY=1

# Persist applied v0.1 scene JSON under content/scenes/persisted/ (see docs/SECURITY.md)
# NEXUS_SCENE_PERSIST_ENABLE=1
# NEXUS_SCENE_PERSIST_ONLY_STAGING=1
# Load persisted file on NexusWorldRoom create (filename = worldId)
# NEXUS_SCENE_LOAD_PERSISTED=1
# NEXUS_SCENE_PERSIST_WORLD_ID=main-world
# Override directory (default: content/scenes/persisted)
# NEXUS_SCENE_PERSIST_DIR=
