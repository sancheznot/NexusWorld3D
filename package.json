{
  "name": "nexusworld3d-framework",
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "An open-source framework for creating 3D multiplayer worlds without Blender or advanced programming",
  "keywords": [
    "3d",
    "multiplayer",
    "framework",
    "threejs",
    "colyseus",
    "nextjs",
    "gaming",
    "world-builder"
  ],
  "author": "NexusWorld3D Team",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "concurrently --timings -p \"{time} [{name}]\" --timestamp-format \"HH:mm:ss.SSS\" -n \"next,colyseus\" -c \"cyan,magenta\" \"next dev -p 3000 --turbo\" \"tsx server/index.ts\"",
    "dev:next": "next dev -p 3000 --turbo",
    "dev:next:fast": "next dev -p 3000 --turbo --disable-source-maps",
    "dev:webpack": "concurrently --timings -p \"{time} [{name}]\" --timestamp-format \"HH:mm:ss.SSS\" -n \"next,colyseus\" -c \"cyan,magenta\" \"next dev -p 3000\" \"tsx server/index.ts\"",
    "dev:game": "tsx server/index.ts",
    "dev:demo": "env NEXT_PUBLIC_FRAMEWORK_DEMO=1 concurrently --timings -p \"{time} [{name}]\" --timestamp-format \"HH:mm:ss.SSS\" -n \"next,colyseus\" -c \"cyan,magenta\" \"next dev -p 3000 --turbo\" \"tsx server/index.ts\"",
    "dev:check-ports": "node scripts/ensure-dev-ports.mjs",
    "build": "next build",
    "start": "tsx server/combined.ts",
    "start:all": "npm run start",
    "docker:up": "bash scripts/compose-with-env.sh -f docker-compose.yml up --build",
    "docker:up:detached": "bash scripts/compose-with-env.sh -f docker-compose.yml up --build -d",
    "docker:down": "bash scripts/compose-with-env.sh -f docker-compose.yml down",
    "db:migrate": "tsx scripts/migrate.ts",
    "lint": "eslint",
    "lint:packages": "eslint \"packages/**/*.{ts,tsx}\"",
    "lint:server": "eslint \"server/**/*.ts\"",
    "validate-content": "tsx scripts/validate-content.ts",
    "validate-scene": "tsx scripts/validate-scene.ts",
    "validate-build-assets": "tsx scripts/validate-build-assets.ts",
    "check:packages": "tsx scripts/check-package-boundaries.ts",
    "check:engine-imports": "tsx scripts/check-engine-imports.ts",
    "check:oss-packages": "node scripts/check-oss-packages.mjs",
    "check:framework": "npm run check:packages && npm run check:engine-imports && npm run lint:packages && npm run lint:server && npm run check:oss-packages",
    "check:phase1": "npm run validate-content && npm run validate-scene && npm run check:framework && npx tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.913.0",
    "@aws-sdk/s3-request-presigner": "^3.913.0",
    "@colyseus/schema": "^3.0.64",
    "@colyseus/ws-transport": "^0.16.5",
    "@dimforge/rapier3d-compat": "^0.19.2",
    "@dinero.js/calculator-number": "^2.0.0-alpha.1",
    "@dinero.js/core": "^2.0.0-alpha.1",
    "@dinero.js/currencies": "^2.0.0-alpha.1",
    "@nexusworld3d/content-schema": "workspace:*",
    "@nexusworld3d/engine-client": "workspace:*",
    "@nexusworld3d/engine-server": "workspace:*",
    "@nexusworld3d/protocol": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@react-three/rapier": "^2.1.0",
    "@types/three": "^0.180.0",
    "@upstash/redis": "^1.35.6",
    "cannon-es": "^0.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colyseus": "^0.16.5",
    "colyseus.js": "^0.16.21",
    "currency.js": "^2.0.4",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "ioredis": "^5.10.1",
    "leva": "^0.10.0",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.20.0",
    "next": "15.5.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.180.0",
    "three-to-cannon": "^5.0.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/cannon": "^0.1.13",
    "@types/node": "^20.19.22",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
