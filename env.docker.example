# ES: Copia estas variables a .env.local (recomendado) o a .env en la raíz. No commitear.
# EN: Copy these variables into .env.local (recommended) or .env at repo root. Do not commit.
#
# ES: npm run docker:up usa scripts/compose-with-env.sh → --env-file .env.local si existe.
# EN: npm run docker:up uses scripts/compose-with-env.sh → --env-file .env.local when present.
#
# ES: Docker = build de producción + `npm run start` (Next + Colyseus en un solo puerto, ver docker-compose.yml).
# EN: Docker = production build + `npm run start` (Next + Colyseus on one port — see docker-compose.yml).
# ES: Tras el primer arranque, migraciones:
#     bash scripts/compose-with-env.sh -f docker-compose.yml exec app npm run db:migrate
# EN: After first up, migrations: (same command as above)

# --- MariaDB (debe coincidir con docker-compose) ---
# ES: ROOT = usuario root del servidor MariaDB. PASSWORD = usuario de aplicación (MARIADB_USER). Son distintos.
# EN: ROOT = MariaDB server root. PASSWORD = app DB user — not the same.
# ES: Si omites ROOT, compose usa default de solo-desarrollo (ver docker-compose.yml).
# EN: If you omit ROOT, compose uses a dev-only default (see docker-compose.yml).
MARIADB_ROOT_PASSWORD=change_this_root_password
MARIADB_DATABASE=nexusworld3d
MARIADB_USER=nexus
MARIADB_PASSWORD=change_this_app_password
# ES: Solo dev con docker-compose.dev-db.yml — si 3306 está ocupado en el host.
# EN: Dev with docker-compose.dev-db.yml only — if host port 3306 is already in use.
# MARIADB_HOST_PORT=3307

# --- Redis (caché compartida: inventario fallback, chat por sala, snapshots) ---
# ES: Orden de uso: 1) Upstash REST  2) REDIS_URL (ioredis). Si defines ambos, gana Upstash.
# EN: Backend order: 1) Upstash REST  2) REDIS_URL (ioredis). Upstash wins if both are set.
#
# ES: Upstash (recomendado serverless / sin TCP) — con estos, NO hace falta REDIS_URL ni contenedor redis.
# EN: Upstash REST — with these, you do not need REDIS_URL or the redis container.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# ES: Redis en Docker (solo si NO usas Upstash arriba). Ver docker-compose.yml → servicio `redis`.
# EN: Docker Redis (only if you are not using Upstash above).
REDIS_URL=redis://redis:6379
# ES: Prefijo de claves (multi-tenant / varios despliegues en el mismo Redis).
# EN: Key prefix for multi-tenant or multiple deployments on one Redis.
REDIS_KEY_PREFIX=nw3d

ADMIN_USERNAME_ACCESS=admin
ADMIN_PASSWORD_ACCESS=change_this_admin_password

# ES: Auth.js — jugadores (Discord / magic email Resend). AUTH_URL = URL pública del sitio.
# EN: Auth.js — players. AUTH_URL = public site URL (e.g. https://app.railway.app).
# AUTH_SECRET=
# AUTH_URL=https://your-deployment.example.com
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=
# AUTH_RESEND_KEY=re_xxxx
# AUTH_EMAIL_FROM="NexusWorld <onboarding@resend.dev>"

NEXT_PUBLIC_GAME_NAME=NexusWorld3D
NEXT_PUBLIC_COLYSEUS_ROOM=nexus-world

# ES: Puerto publicado en el host. EN: Published host port.
# APP_PORT=3000

# ES: Opcional: URL única (mysql2). Si se define, ignora MARIADB_* discretos.
# EN: Optional single URL (mysql2). If set, overrides discrete MARIADB_*.
# DATABASE_URL=mysql://nexus:change_this_app_password@mariadb:3306/nexusworld3d
